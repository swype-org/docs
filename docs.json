{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Blink",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "favicon": "/favicon.svg",
  "seo": {
    "metatags": {
      "og:image": "https://docs.blink.cash/images/og-image.png",
      "og:site_name": "Blink Documentation",
      "twitter:card": "summary_large_image",
      "twitter:image": "https://docs.blink.cash/images/og-image.png"
    }
  },
  "fonts": {
    "heading": {
      "family": "ABC Diatype Unlicensed Trial",
      "source": "/fonts/ABCDiatype-Bold-Trial.woff2",
      "format": "woff2",
      "weight": 700
    },
    "body": {
      "family": "ABC Diatype Unlicensed Trial",
      "source": "/fonts/ABCDiatype-Regular-Trial.woff2",
      "format": "woff2",
      "weight": 400
    }
  },
  "colors": {
    "primary": "#56A4FF",
    "light": "#CAFF34",
    "dark": "#CAFF34"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "pages": ["introduction", "quickstart"]
          },
          {
            "group": "Integration Guide",
            "pages": [
              "integration/architecture",
              "integration/supported-networks-and-wallets",
              "integration/fees",
              "integration/key-generation",
              "integration/merchant-registration",
              "integration/authentication",
              "integration/merchant-domains",
              "integration/signer-endpoint",
              "integration/merchant-api",
              "integration/deposit-sdk",
              "integration/deposit-mobile-sdk",
              "integration/security",
              "integration/testing",
              "integration/testnet-sandbox",
              "integration/production-checklist"
            ]
          }
        ]
      },
      {
        "tab": "SDK Reference",
        "groups": [
          {
            "group": "Deposit SDK (Web)",
            "pages": [
              "sdk-reference/deposit-class",
              "sdk-reference/react-hook",
              "sdk-reference/blink-deposit-button",
              "sdk-reference/types",
              "sdk-reference/errors",
              "sdk-reference/events"
            ]
          },
          {
            "group": "Deposit SDK (Mobile)",
            "pages": [
              "sdk-reference/mobile-deposit-class",
              "sdk-reference/mobile-react-native-hook",
              "sdk-reference/mobile-errors"
            ]
          }
        ]
      },
      {
        "tab": "AI Agent",
        "groups": [
          {
            "group": "Integrate with an AI agent",
            "pages": ["ai-agent"]
          }
        ]
      },
      {
        "tab": "Users",
        "pages": [
          "user-intro",
          "user-setup"
        ]
      }
    ]
  },
  "navbar": {
    "links": [
      {
        "label": "Contact",
        "href": "https://calendar.app.google/3fqK5VntM89fFXnJ9"
      }
    ]
  },
  "contextual": {
    "display": "header",
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "search": {
    "prompt": "Search docs..."
  },
  "footer": {
    "socials": {
      "website": "https://blink.cash"
    }
  }
}
